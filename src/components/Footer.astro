---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="brand" style="color:#fff; font-size:1.7rem;">
          The<span style="color:var(--accent)">Woods</span>
        </div>
        <p class="text-muted" style="margin-top:14px; max-width:34ch; color:#b6ad9f;">
          Distribuidora de materiales de madera y tipo madera. Damos calidez y
          carácter a tus espacios.
        </p>
      </div>

      <div class="stack" style="gap:10px;">
        <h3>Navegación</h3>
        <a href="/">Inicio</a>
        <a href="/test">Hacer el test</a>
        <a href="/#estilos">Estilos</a>
      </div>

      <div class="stack" style="gap:10px;">
        <h3>Contacto</h3>
        <a href="https://wa.me/522221234567" target="_blank" rel="noopener">WhatsApp</a>
        <a href="mailto:hola@thewoods.mx">hola@thewoods.mx</a>
        <span class="text-muted" style="color:#b6ad9f;">Puebla, Pue., México</span>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} The Woods. Todos los derechos reservados.</span>
      <span>Hecho con madera y cariño en Puebla 🌳</span>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 40px;
  }
  .footer a {
    color: #c9c0b2;
    transition: color 0.2s ease;
    width: fit-content;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.85rem;
    color: #9b9384;
  }
  @media (max-width: 720px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
